#. Plugin Name of the plugin
#: wp-curtain-raiser.php
msgid "Curtain Raiser for Inaugural Ceremony"
msgstr "उद्घाटन समारोह के लिए परदा रेज़र"

#. Plugin URI of the plugin
#: wp-curtain-raiser.php
msgid "https://wordpress.org/plugins/wp-curtain-raiser/"
msgstr "https://wordpress.org/plugins/wp-curtain-raiser/"

#. Description of the plugin
#: wp-curtain-raiser.php
msgid ""
"Adds an animated curtain-raiser overlay to your WordPress site for inaugural "
"ceremonies. Trigger via ?curtain_ceremony=true."
msgstr "आपकी WordPress साइट पर उद्घाटन समारोह के लिए एनिमेटेड परदा-रेज़र ओवरले जोड़ता है। ?curtain_ceremony=true से सक्रिय करें।"

#. Author of the plugin
#: wp-curtain-raiser.php
msgid "Team Peenak"
msgstr "Team Peenak"

#. Author URI of the plugin
#: wp-curtain-raiser.php
msgid "https://www.peenak.com/"
msgstr "https://www.peenak.com/"

