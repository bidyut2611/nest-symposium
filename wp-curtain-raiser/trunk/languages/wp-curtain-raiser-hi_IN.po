msgid "Open Curtain"
msgstr "परदा खोलें"

#: includes/class-wp-curtain-raiser-remote.php:128
msgid "Opening…"
msgstr "खोला जा रहा है…"

#: includes/class-wp-curtain-raiser-remote.php:129
msgid "✓ Curtain Opened!"
msgstr "✓ परदा खुल गया!"

#: includes/class-wp-curtain-raiser-remote.php:130
#: includes/class-wp-curtain-raiser-remote.php:217
msgid "Close Curtain"
msgstr "परदा बंद करें"

#: includes/class-wp-curtain-raiser-remote.php:131
